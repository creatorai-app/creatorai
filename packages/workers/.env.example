# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Redis (same as repo root / apps/api — BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# AI Services — Vertex AI (Gemini)
# Auth uses Application Default Credentials (ADC). For local dev run:
#   gcloud auth application-default login
# For servers/VPS, point this at a service-account JSON key with role roles/aiplatform.user.
# On Cloud Run/GKE with an attached service account, omit GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/vertex-sa.json
# Optional model overrides (defaults: gemini-3.5-flash / gemini-2.5-flash-image / gemini-embedding-001)
# GEMINI_TEXT_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Google OAuth (for YouTube)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

