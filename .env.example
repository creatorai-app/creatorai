# ============================================================================
# Creator AI — Root Environment (single source of truth for ALL apps/packages)
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in real values:  cp .env.example .env
#
# Loaded by:
#   - apps/api         (NestJS)  -> ConfigModule falls back to ../../.env
#   - packages/workers (NestJS)  -> ConfigModule falls back to ../../.env
#   - apps/web         (Next.js) -> loaded in next.config.mjs
#
# PRODUCTION: this file is NOT used. Vercel (web) and Railway (api/worker)
# inject the same variables from their dashboards — keep them in sync with the
# keys below. PORT is intentionally omitted (api defaults 8000, worker 8001;
# prod platforms inject their own).
# ============================================================================

# --- Environment ------------------------------------------------------------
NODE_ENV=development

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Client-exposed (inlined into the web bundle — anon key only, never the service key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Redis (BullMQ — shared by api + workers) -------------------------------
REDIS_URL=redis://127.0.0.1:6379

# --- AI Services — Vertex AI (Gemini) ---------------------------------------
# Auth uses Application Default Credentials (ADC). Local dev alternative:
# `gcloud auth application-default login` (then omit GOOGLE_APPLICATION_CREDENTIALS).
# Path is relative to each service's cwd; api and workers sit two dirs below root.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=../../gcp_service_acc.json
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# Optional model overrides (defaults live in code):
# GEMINI_TEXT_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_VIDEO_MODEL=gemini-omni-flash-preview
GEMINI_VIDEO_LOCATION=us-central1

# --- Google Cloud Storage buckets (public-read) -----------------------------
GCS_SUBTITLE_BUCKET=my-subtitle-bucket
GCS_VIDEO_BUCKET=my-video-bucket
GCS_DUBBING_BUCKET=my-dubbing-bucket

# --- Dubbing / video-gen (Modal + credit pricing) ---------------------------
MODAL_API_URL=https://your-workspace--creator-ai-dubbing-dub.modal.run
DUBBING_CREDIT_MULTIPLIER=15                 # credits per second of source audio
# VIDEO_GENERATION_CREDIT_MULTIPLIER=50      # credits per second of generated video

# --- Google OAuth -----------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- YouTube ----------------------------------------------------------------
YOUTUBE_API_KEY=your-youtube-api-key

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=your-resend-api-key
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret
ADMIN_NOTIFICATION_EMAIL=you@example.com

# --- Payments (Lemon Squeezy) -----------------------------------------------
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-secret

# --- URLs -------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
FRONTEND_DEV_URL=http://localhost:3000
FRONTEND_PROD_URL=https://tryscriptai.com
